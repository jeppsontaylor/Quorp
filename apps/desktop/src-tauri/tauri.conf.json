{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quorp",
  "version": "0.1.0",
  "identifier": "ai.veox.quorp.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quorp",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "visible": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; font-src 'self' data:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Quorp Desktop",
    "longDescription": "Quorp agentic editor desktop shell",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "exceptionDomain": null,
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  },
  "plugins": {
    "store": {},
    "window-state": {},
    "dialog": {},
    "opener": {}
  }
}
