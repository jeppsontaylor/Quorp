#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

fail() {
  echo "[quorp-audit-gaps] $1" >&2
  exit 1
}

echo "[quorp-audit-gaps] checking roadmap evidence under tips/upgrade/v2"

[[ -d tips/upgrade/v2 ]] || fail "tips/upgrade/v2 is missing"
[[ -f tips/upgrade/v2/README.md ]] || fail "tips/upgrade/v2/README.md is missing"

tracked_tip_files="$(git ls-files 'tips/upgrade/v2/*')"
if ! printf '%s\n' "$tracked_tip_files" | grep -q .; then
  fail "no tracked tips/upgrade/v2/tip*.txt files were found"
fi
while IFS= read -r path; do
  [[ -z "$path" || -e "$path" ]] && continue
  fail "tracked roadmap evidence file is missing from the worktree: $path"
done <<< "$tracked_tip_files"

echo "[quorp-audit-gaps] checking benchmark playbook reachability"

./script/quorp-no-benchmark-oracles
./script/quorp-test-layout-audit

echo "[quorp-audit-gaps] checking native backend write-handler parity"

normalize_rust_test_declarations() {
  python3 - "$1" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text()
text = re.sub(
    r'\n?#\[cfg\(test\)\]\s*\n'
    r'(?:#\[path = "[^"]+"\]\s*\n)?'
    r'\s*mod tests;\s*\n?',
    '\n',
    text,
)
print(text, end="")
PY
}

if ! cmp -s \
  <(normalize_rust_test_declarations crates/quorp/src/quorp/tui/native_backend/actions.rs) \
  <(normalize_rust_test_declarations crates/quorp_session/src/quorp/tui/native_backend/actions.rs)
then
  fail "main/session native backend action handlers have diverged"
fi

echo "[quorp-audit-gaps] checking native backend direct writes"

write_hits="$(
  rg -n 'write_full_file|std::fs::write|fs::write|OpenOptions::new|remove_file|rename\(' \
    crates/quorp/src/quorp/tui/native_backend/actions.rs \
    crates/quorp_session/src/quorp/tui/native_backend/actions.rs || true
)"
if [[ -n "$write_hits" ]]; then
  unexpected_writes="$(
    printf '%s\n' "$write_hits" | grep -Ev ':.*raw_log_path' || true
  )"
  if [[ -n "$unexpected_writes" ]]; then
    printf '%s\n' "$unexpected_writes" >&2
    fail "native backend action handlers contain direct write paths outside approved artifact/log sinks"
  fi
fi

echo "[quorp-audit-gaps] checking repo-wide write-path enforcement"
./script/quorp-write-path-audit

echo "[quorp-audit-gaps] ok"
