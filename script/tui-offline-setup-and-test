#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

echo "==> Step 1/3: Build vendor/ from Cargo.lock (requires internet access)"
./script/bootstrap-vendor

echo
echo "==> Step 2/3: Run focused Rust TUI screenshot flow offline"
./script/cargo-offline test -p quorp tui_flow_tests::rust_capture_flows -- --nocapture

echo
